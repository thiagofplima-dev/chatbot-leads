# ===========================
# Servidor
# ===========================
PORT=3000
NODE_ENV=development

# ===========================
# PostgreSQL
# ===========================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=chatbot_leads
DB_USER=postgres
DB_PASSWORD=postgres

# ===========================
# UazAPI (WhatsApp API)
# ===========================
