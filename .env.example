# ===========================
# DeepSeek AI
# ===========================
DEEPSEEK_API_KEY=sk-sua-chave-aqui
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ===========================
# Lead Notification (opcional)
# ===========================
NOTIFICATION_TYPE=database  # database | email | telegram | webhook
