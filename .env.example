# ===========================
# Servidor
# ===========================
PORT=3000
NODE_ENV=development

# ===========================
# WhatsApp Business API (Meta)
# ===========================
WHATSAPP_TOKEN=seu_token_de_acesso_aqui
WHATSAPP_PHONE_NUMBER_ID=seu_phone_number_id_aqui
WHATSAPP_VERIFY_TOKEN=seu_verify_token_personalizado
WHATSAPP_API_VERSION=v21.0
WHATSAPP_BUSINESS_ACCOUNT_ID=seu_business_account_id

# ===========================
# n8n (internal webhook)
# ===========================
N8N_WEBHOOK_URL=http://n8n:5678/webhook
N8N_API_KEY=sua_n8n_api_key_opcional

# ===========================
# PostgreSQL
# ===========================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=chatbot_leads
DB_USER=postgres
DB_PASSWORD=postgres

# ===========================
# DeepSeek (via n8n - configurado nas credenciais do n8n)
# ===========================
# A chave DeepSeek é configurada diretamente no n8n como credential
# DEEPSEEK_API_KEY=sk-sua-chave-aqui

# ===========================
# Lead Notification (opcional)
# ===========================
NOTIFICATION_TYPE=email  # email | telegram | webhook | database
NOTIFICATION_EMAIL_TO=comercial@seudominio.com
NOTIFICATION_TELEGRAM_BOT_TOKEN=
NOTIFICATION_TELEGRAM_CHAT_ID=
NOTIFICATION_WEBHOOK_URL=
